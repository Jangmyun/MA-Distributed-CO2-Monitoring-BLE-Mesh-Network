/*
 * nRF52840 DK — 1602 LCD (PCF8574 I2C backpack) + ADXL345 가속도계 (GY-291) overlay
 *
 * ── 1602 LCD (PCF8574 I2C 백팩) 연결 ──────────────────────────────────────
 *  LCD 모듈   │  nRF52840 DK
 * ────────────┼────────────────────────────────────────────────────────────
 *  GND        │  GND  (J2 핀1)
 *  VCC        │  VCC (3.3V → J2 핀2, 또는 5V → P22 핀3)
 *  SDA        │  P0.26 (Arduino A4 / J3 핀7)   ← ADXL345 SDA 공유
 *  SCL        │  P0.27 (Arduino A5 / J3 핀8)   ← ADXL345 SCL 공유
 * ─────────────────────────────────────────────────────────────────────────
 *
 * PCF8574 I2C 주소: 0x27 (A0=A1=A2=1, 기본값)
 *                  0x3F (PCF8574AT 칩 사용 시)
 *
 * ── GY-291 (ADXL345) 연결 ─────────────────────────────────────────────────
 *  GY-291 핀  │  nRF52840 DK                    │  비고
 * ────────────┼─────────────────────────────────┼───────────────────────────
 *  GND        │  GND  (J2 핀1)                  │
 *  VCC        │  3.3V (J2 핀2)                  │  3.3V 전용 — 5V 금지
 *  CS         │  3.3V (J2 핀2)                  │  HIGH = I2C 모드 선택
 *  SDO        │  GND  (J2 핀1)                  │  LOW  = I2C 주소 0x53
 *             │                                 │  HIGH = I2C 주소 0x1D
 *  SDA        │  P0.26 (Arduino A4 / J3 핀7)   │  LCD SDA와 동일 버스
 *  SCL        │  P0.27 (Arduino A5 / J3 핀8)   │  LCD SCL와 동일 버스
 *  INT1       │  P1.08 (Arduino D8 / J2 헤더)  │  선택사항 — 폴링 시 미연결 가능
 *  INT2       │  P1.10 (J2 확장 헤더)           │  선택사항 — 폴링 시 미연결 가능
 * ─────────────────────────────────────────────────────────────────────────
 *
 * ADXL345 I2C 주소: 0x53 (SDO → GND, 기본값)
 *                  0x1D (SDO → VCC)
 */

&pinctrl {
	i2c0_default: i2c0_default {
		group1 {
			psels = <NRF_PSEL(TWIM_SDA, 0, 26)>,
				<NRF_PSEL(TWIM_SCL, 0, 27)>;
			bias-pull-up;
		};
	};

	i2c0_sleep: i2c0_sleep {
		group1 {
			psels = <NRF_PSEL(TWIM_SDA, 0, 26)>,
				<NRF_PSEL(TWIM_SCL, 0, 27)>;
			low-power-enable;
		};
	};
};

&i2c0 {
	compatible = "nordic,nrf-twim";
	status = "okay";
	pinctrl-0 = <&i2c0_default>;
	pinctrl-1 = <&i2c0_sleep>;
	pinctrl-names = "default", "sleep";
	clock-frequency = <I2C_BITRATE_STANDARD>;

	adxl345: adxl345@53 {
		compatible = "adi,adxl345";
		reg = <0x53>;
		/* SDO → VCC 연결 시 reg = <0x1D> 로 변경 */
		int1-gpios = <&gpio1 8 GPIO_ACTIVE_HIGH>;  /* P1.08 — INT1 */
		int2-gpios = <&gpio1 10 GPIO_ACTIVE_HIGH>; /* P1.10 — INT2 */
	};
};
